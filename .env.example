# Public base domain. This must have a wildcard DNS record pointing at the relay.
RELAY_DOMAIN=darsha.dev

# Host paths to a certificate containing darsha.dev and *.darsha.dev.
TLS_CERT_PATH=/etc/letsencrypt/live/darsha.dev/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/darsha.dev/privkey.pem

RUST_LOG=info
